<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.kuonjiarisu.backend.mapper.SettingMapper">
  <sql id="settingColumns">
    setting_key, setting_value, updated_at
  </sql>

  <resultMap id="settingResultMap" type="io.github.kuonjiarisu.backend.model.AppSetting">
    <constructor>
      <arg column="setting_key" javaType="java.lang.String" />
      <arg column="setting_value" javaType="java.lang.String" />
      <arg column="updated_at" javaType="java.time.LocalDateTime" />
    </constructor>
  </resultMap>

  <select id="findAll" resultMap="settingResultMap">
    SELECT <include refid="settingColumns" />
    FROM app_settings
    ORDER BY setting_key ASC
  </select>

  <select id="findByKey" resultMap="settingResultMap">
    SELECT <include refid="settingColumns" />
    FROM app_settings
    WHERE setting_key = #{key}
  </select>

  <insert id="upsert" parameterType="io.github.kuonjiarisu.backend.model.AppSetting">
    INSERT INTO app_settings (setting_key, setting_value, updated_at)
    VALUES (#{key}, #{value}, #{updatedAt})
    ON DUPLICATE KEY UPDATE
      setting_value = VALUES(setting_value),
      updated_at = VALUES(updated_at)
  </insert>
</mapper>
